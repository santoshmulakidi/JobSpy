# Local default: SQLite. Use PostgreSQL only when running the Docker stack or a production DB.
JOB_INTELLIGENCE_DATABASE_URL=sqlite:///./job_intelligence.db
JOB_INTELLIGENCE_LOG_LEVEL=INFO
JOB_INTELLIGENCE_DEFAULT_SITES=linkedin,indeed,google,career_page,jobright_h1b,dice,governmentjobs,jobspresso,dynamitejobs,skipthedrive,remotive,remotely,yc_jobs
JOB_INTELLIGENCE_SCHEDULER_HOURS=1
JOB_INTELLIGENCE_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
JOB_INTELLIGENCE_USAJOBS_API_KEY=
JOB_INTELLIGENCE_USAJOBS_USER_AGENT=
JOB_INTELLIGENCE_AI_PROVIDER_ORDER=openrouter,nvidia
JOB_INTELLIGENCE_OPENROUTER_API_KEY=
JOB_INTELLIGENCE_OPENROUTER_MODEL=openrouter/auto
JOB_INTELLIGENCE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
JOB_INTELLIGENCE_NVIDIA_API_KEY=
JOB_INTELLIGENCE_NVIDIA_MODEL=minimaxai/minimax-m3
JOB_INTELLIGENCE_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
JOB_INTELLIGENCE_GROQ_API_KEY=
JOB_INTELLIGENCE_GROQ_MODEL=llama-3.1-8b-instant
JOB_INTELLIGENCE_GROQ_BASE_URL=https://api.groq.com/openai/v1
JOB_INTELLIGENCE_GEMINI_API_KEY=
JOB_INTELLIGENCE_GEMINI_MODEL=gemini-2.0-flash
JOB_INTELLIGENCE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
JOB_INTELLIGENCE_RESUME_REBUILD_MAX_TOKENS=3200
